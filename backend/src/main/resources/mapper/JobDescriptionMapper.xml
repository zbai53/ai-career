<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.aicareer.mapper.JobDescriptionMapper">

    <resultMap id="jobDescriptionResultMap" type="com.aicareer.model.entity.JobDescription">
        <id     column="id"               property="id"/>
        <result column="user_id"          property="userId"/>
        <result column="title"            property="title"/>
        <result column="company"          property="company"/>
        <result column="parsed_data"      property="parsedData"/>
        <result column="raw_text"         property="rawText"/>
        <result column="source_url"       property="sourceUrl"/>
        <result column="parse_confidence" property="parseConfidence"/>
        <result column="created_at"       property="createdAt"/>
    </resultMap>

    <insert id="insert" parameterType="com.aicareer.model.entity.JobDescription"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO job_descriptions (user_id, title, company, parsed_data, raw_text, source_url, parse_confidence)
        VALUES (#{userId}, #{title}, #{company},
                #{parsedData}::jsonb, #{rawText}, #{sourceUrl}, #{parseConfidence})
    </insert>

    <select id="findById" parameterType="long" resultMap="jobDescriptionResultMap">
        SELECT id, user_id, title, company,
               parsed_data::text AS parsed_data,
               raw_text, source_url, parse_confidence, created_at
        FROM job_descriptions
        WHERE id = #{id}
    </select>

    <select id="findByUserId" parameterType="long" resultMap="jobDescriptionResultMap">
        SELECT id, user_id, title, company,
               parsed_data::text AS parsed_data,
               raw_text, source_url, parse_confidence, created_at
        FROM job_descriptions
        WHERE user_id = #{userId}
        ORDER BY created_at DESC
    </select>

    <delete id="deleteById" parameterType="long">
        DELETE FROM job_descriptions WHERE id = #{id}
    </delete>

</mapper>

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.aicareer.mapper.ResumeMapper">

    <resultMap id="resumeResultMap" type="com.aicareer.model.entity.Resume">
        <id     column="id"                 property="id"/>
        <result column="user_id"            property="userId"/>
        <result column="original_file_name" property="originalFileName"/>
        <result column="file_path"          property="filePath"/>
        <result column="parsed_data"        property="parsedData"/>
        <result column="raw_text"           property="rawText"/>
        <result column="parse_confidence"   property="parseConfidence"/>
        <result column="created_at"         property="createdAt"/>
    </resultMap>

    <insert id="insert" parameterType="com.aicareer.model.entity.Resume"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO resumes (user_id, original_file_name, file_path, parsed_data, raw_text, parse_confidence)
        VALUES (#{userId}, #{originalFileName}, #{filePath},
                #{parsedData}::jsonb, #{rawText}, #{parseConfidence})
    </insert>

    <select id="findById" parameterType="long" resultMap="resumeResultMap">
        SELECT id, user_id, original_file_name, file_path,
               parsed_data::text AS parsed_data,
               raw_text, parse_confidence, created_at
        FROM resumes
        WHERE id = #{id}
    </select>

    <select id="findByUserId" parameterType="long" resultMap="resumeResultMap">
        SELECT id, user_id, original_file_name, file_path,
               parsed_data::text AS parsed_data,
               raw_text, parse_confidence, created_at
        FROM resumes
        WHERE user_id = #{userId}
        ORDER BY created_at DESC
    </select>

    <delete id="deleteById" parameterType="long">
        DELETE FROM resumes WHERE id = #{id}
    </delete>

</mapper>
